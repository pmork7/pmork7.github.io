---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = [
  {
    name: "Contextualize",
    description: "A flashcard app for contextual learning.",
    tags: ["TypeScript", "Node.js", "PostgreSQL"],
    github: "https://github.com/pmork7/contextualize",
    live: undefined,
  },
  {
    name: "Project Beta",
    description: "Another cool thing you built — what problem does it solve?",
    tags: ["Python", "FastAPI", "Docker"],
    github: "https://github.com/yourusername/project-beta",
    live: undefined,
  },
  {
    name: "Project Gamma",
    description: "An open-source library or tool you're proud of.",
    tags: ["Rust", "CLI"],
    github: "https://github.com/yourusername/project-gamma",
    live: undefined,
  },
];

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}
---

<BaseLayout title="Personal Homepage" description="Software engineer and builder.">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-layout">
      <div class="hero-text">
        <h1>Hi, I'm Paul.</h1>
        <p class="tagline">
          Software engineer who likes building cool things.
        </p>
        <div class="hero-cta">
          <a href="/#projects" class="btn btn-primary">See my work</a>
          <a href="/#contact" class="btn btn-ghost">Get in touch</a>
        </div>
      </div>
      <div class="hero-canvas-wrapper">
        <canvas id="gol-canvas" aria-hidden="true"></canvas>
        <div class="gol-controls">
          <label for="gol-rule" class="gol-label">Rule:</label>
          <select id="gol-rule" class="gol-select">
            <option value="B3/S23">Conway's Game of Life (B3/S23)</option>
            <option value="B36/S23">HighLife (B36/S23)</option>
            <option value="B3678/S34678">Day & Night (B3678/S34678)</option>
            <option value="B2/S">Seeds (B2/S)</option>
            <option value="B35678/S5678">Diamoeba (B35678/S5678)</option>
            <option value="B368/S245">Morley (B368/S245)</option>
          </select>
          <button id="gol-reset" class="gol-reset" type="button">Reset</button>
          <button id="gol-invert" class="gol-reset" type="button">Invert</button>
        </div>
        <div class="gol-controls">
          <label for="gol-brush" class="gol-label">Brush:</label>
          <input id="gol-brush" class="gol-slider" type="range" min="1" max="20" step="1" value="1" />
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="container">
      <p class="section-label">About</p>
      <p>
        I'm a software engineer based in Baltimore. I work on software testing and quality assurance. I care about writing clean, maintainable
        code and building tools that people actually enjoy using.
      </p>
      <br />
      <p>
        Outside of work, I like hiking and cycling. I occasionally write about things
        I'm learning or building — you can find those on my <a href="/blog">blog</a>.
      </p>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="container">
      <p class="section-label">Projects</p>
      <div class="projects-grid">
        {projects.map((project) => (
          <div class="project-card">
            <h3>{project.name}</h3>
            <p>{project.description}</p>
            <div class="tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="project-links">
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener">GitHub</a>
              )}
              {project.live && (
                <a href={project.live} target="_blank" rel="noopener">Live ↗</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog -->
  {posts.length > 0 && (
    <section id="writing">
      <div class="container">
        <p class="section-label">Writing</p>
        <div class="post-list">
          {posts.map((post) => (
            <div class="post-item">
              <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
              <span class="post-date">{formatDate(post.data.date)}</span>
            </div>
          ))}
        </div>
        <br />
        <a href="/blog" style="font-size: 0.9rem;">All posts →</a>
      </div>
    </section>
  )}

  <!-- GitHub Activity -->
  <section id="activity">
    <div class="container">
      <p class="section-label">GitHub Activity</p>
      <div class="github-chart">
        <img
          src="https://ghchart.rshah.org/2563eb/pmork7"
          alt="Paul Mork's GitHub contribution chart"
          width="100%"
        />
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <div class="container">
      <p class="section-label">Contact</p>
      <p style="margin-bottom: 1.5rem; color: var(--color-muted); font-size: 0.95rem;">
        I'm open to interesting conversations and opportunities. Feel free to reach out.
      </p>
      <div class="contact-links">
        <a href="mailto:paul.a.mork@gmail.com" class="contact-link">
          paul.a.mork@gmail.com
        </a>
        <a href="https://github.com/pmork7" target="_blank" rel="noopener" class="contact-link">
          https://github.com/pmork7
        </a>
        <a href="https://www.linkedin.com/in/paul-mork-85a781100/" target="_blank" rel="noopener" class="contact-link">
          https://www.linkedin.com/in/paul-mork-85a781100/
        </a>
      </div>
    </div>
  </section>

<script>
(function () {
  const canvas = document.getElementById("gol-canvas");
  if (!canvas) return;
  const ctx = canvas.getContext("2d");

  const CELL_SIZE = 8;
  const TICK_INTERVAL = 100; // ~10 FPS
  const INITIAL_DENSITY = 0.25;

  let cols = 0;
  let rows = 0;
  let grid = [];
  let lastTick = 0;

  let colorIntensity = []; // 2D array: 0-1 fade value per cell
  let colorHue = [];       // 2D array: hue (0-360) per cell
  let mouseX = -1;
  let mouseY = -1;
  let inverted = true;
  let brushDiameter = 1;
  let ripples = [];
  let lastBrushCell = null;
  const FADE_SPEED = 0.08; // per frame, ease-out (~1s decay at 60fps)
  const WAVE_SPEED = 0.8;      // cells per frame
  const WAVE_WIDTH = 1.6;      // gaussian sigma (cells)
  const RIPPLE_LIFETIME = 48;  // frames
  const MAX_RIPPLES = 15;

  // --- Rule parsing ---
  const RULES = {
    "B3/S23": { birth: new Set([3]), survival: new Set([2, 3]) },
    "B36/S23": { birth: new Set([3, 6]), survival: new Set([2, 3]) },
    "B3678/S34678": { birth: new Set([3, 6, 7, 8]), survival: new Set([3, 4, 6, 7, 8]) },
    "B2/S": { birth: new Set([2]), survival: new Set() },
    "B35678/S5678": { birth: new Set([3, 5, 6, 7, 8]), survival: new Set([5, 6, 7, 8]) },
    "B368/S245": { birth: new Set([3, 6, 8]), survival: new Set([2, 4, 5]) },
  };

  let currentRule = RULES["B3/S23"];

  // --- Grid setup ---
  function initGrid() {
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * devicePixelRatio;
    canvas.height = rect.height * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);

    cols = Math.floor(rect.width / CELL_SIZE);
    rows = Math.floor(rect.height / CELL_SIZE);

    grid = [];
    for (let r = 0; r < rows; r++) {
      grid[r] = [];
      for (let c = 0; c < cols; c++) {
        grid[r][c] = Math.random() < INITIAL_DENSITY;
      }
    }

    colorIntensity = [];
    colorHue = [];
    for (let r = 0; r < rows; r++) {
      colorIntensity[r] = new Float32Array(cols);
      colorHue[r] = new Float32Array(cols);
    }

    ripples = [];
    lastBrushCell = null;
  }

  // --- Simulation step ---
  function countNeighbors(r, c) {
    let count = 0;
    for (let dr = -1; dr <= 1; dr++) {
      for (let dc = -1; dc <= 1; dc++) {
        if (dr === 0 && dc === 0) continue;
        const nr = r + dr;
        const nc = c + dc;
        if (nr >= 0 && nr < rows && nc >= 0 && nc < cols && grid[nr][nc]) {
          count++;
        }
      }
    }
    return count;
  }

  function step() {
    const next = [];
    for (let r = 0; r < rows; r++) {
      next[r] = [];
      for (let c = 0; c < cols; c++) {
        const n = countNeighbors(r, c);
        if (grid[r][c]) {
          next[r][c] = currentRule.survival.has(n);
        } else {
          next[r][c] = currentRule.birth.has(n);
        }
      }
    }
    grid = next;
  }

  // --- Color hover effect ---
  function spawnRipple() {
    if (mouseX < 0 || mouseY < 0) return;
    const col = Math.floor(mouseX / CELL_SIZE);
    const row = Math.floor(mouseY / CELL_SIZE);
    if (lastBrushCell && lastBrushCell.col === col && lastBrushCell.row === row) return;
    ripples.push({ row: row, col: col, age: 0 });
    if (ripples.length > MAX_RIPPLES) ripples.shift();
    lastBrushCell = { col: col, row: row };
  }

  function updateColors() {
    // Decay existing color
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const v = colorIntensity[r][c] * (1 - FADE_SPEED);
        colorIntensity[r][c] = v < 0.01 ? 0 : v;
      }
    }

    // Age ripples and stamp their wave-front pulses
    for (let i = ripples.length - 1; i >= 0; i--) {
      const rip = ripples[i];
      rip.age++;
      if (rip.age > RIPPLE_LIFETIME) {
        ripples.splice(i, 1);
        continue;
      }
      const waveR = rip.age * WAVE_SPEED;
      const lifeFade = 1 - rip.age / RIPPLE_LIFETIME;
      const maxDist = waveR + WAVE_WIDTH * 3;
      const rMin = Math.max(0, Math.floor(rip.row - maxDist));
      const rMax = Math.min(rows - 1, Math.ceil(rip.row + maxDist));
      const cMin = Math.max(0, Math.floor(rip.col - maxDist));
      const cMax = Math.min(cols - 1, Math.ceil(rip.col + maxDist));
      for (let r = rMin; r <= rMax; r++) {
        for (let c = cMin; c <= cMax; c++) {
          if (!grid[r][c]) continue;
          const dr = r - rip.row;
          const dc = c - rip.col;
          const dist = Math.sqrt(dr * dr + dc * dc);
          const frontDelta = dist - waveR;
          const pulse = Math.exp(-(frontDelta * frontDelta) / (2 * WAVE_WIDTH * WAVE_WIDTH));
          const intensity = pulse * lifeFade;
          if (intensity > colorIntensity[r][c]) {
            colorIntensity[r][c] = intensity;
            const angle = Math.atan2(dr, dc);
            colorHue[r][c] = ((angle / Math.PI) * 180 + 360) % 360;
          }
        }
      }
    }
  }

  // --- Render ---
  function render() {
    const w = canvas.width / devicePixelRatio;
    const h = canvas.height / devicePixelRatio;
    const bgColor = inverted ? "#fff" : "#000";
    const cellColor = inverted ? "#000" : "#fff";
    ctx.fillStyle = bgColor;
    ctx.fillRect(0, 0, w, h);

    updateColors();

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const intensity = colorIntensity[r][c];
        if (intensity > 0) {
          const hue = colorHue[r][c];
          ctx.fillStyle = "hsl(" + hue + " 80% " + (intensity * 50) + "%)";
          ctx.fillRect(c * CELL_SIZE, r * CELL_SIZE, CELL_SIZE - 1, CELL_SIZE - 1);
        } else if (grid[r][c]) {
          ctx.fillStyle = cellColor;
          ctx.fillRect(c * CELL_SIZE, r * CELL_SIZE, CELL_SIZE - 1, CELL_SIZE - 1);
        }
      }
    }
  }

  // --- Main loop ---
  function loop(timestamp) {
    if (timestamp - lastTick >= TICK_INTERVAL) {
      step();
      lastTick = timestamp;
    }
    render();
    requestAnimationFrame(loop);
  }

  // --- Rule selector ---
  const ruleSelect = document.getElementById("gol-rule");
  ruleSelect.addEventListener("change", function () {
    currentRule = RULES[this.value];
  });

  // --- Reset button ---
  document.getElementById("gol-reset").addEventListener("click", function () {
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    initGrid();
  });

  // --- Invert button ---
  document.getElementById("gol-invert").addEventListener("click", function () {
    inverted = !inverted;
    canvas.style.background = inverted ? "#fff" : "#000";
  });

  // --- Brush slider ---
  const brushSlider = document.getElementById("gol-brush");
  brushDiameter = parseFloat(brushSlider.value);
  brushSlider.addEventListener("input", function () {
    brushDiameter = parseFloat(this.value);
  });

  // --- Resize handling ---
  let resizeTimer;
  function handleResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      initGrid();
    }, 200);
  }
  window.addEventListener("resize", handleResize);
  screen.orientation && screen.orientation.addEventListener("change", handleResize);

  // --- Mouse/touch tracking ---
  canvas.addEventListener("mousemove", function (e) {
    const rect = canvas.getBoundingClientRect();
    mouseX = e.clientX - rect.left;
    mouseY = e.clientY - rect.top;
    spawnRipple();
  });

  canvas.addEventListener("mouseleave", function () {
    mouseX = -1;
    mouseY = -1;
    lastBrushCell = null;
  });

  canvas.addEventListener("touchmove", function (e) {
    e.preventDefault();
    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];
    mouseX = touch.clientX - rect.left;
    mouseY = touch.clientY - rect.top;
    spawnRipple();
  }, { passive: false });

  canvas.addEventListener("touchend", function () {
    mouseX = -1;
    mouseY = -1;
    lastBrushCell = null;
  });

  // --- Start ---
  initGrid();
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
